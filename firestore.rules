rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // بناءً على طلب المستخدم بإزالة تسجيل الدخول، تم جعل القراءة والكتابة متاحة للجميع
    // تحذير: هذا يعني أن البيانات عامة ويمكن لأي شخص تعديلها.
    match /students/{studentId} {
      allow read, write: if true;
    }
    match /honorRoll/{docId} {
      allow read, write: if true;
    }
  }
}
